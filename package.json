{
  "name": "wormhole",
  "private": true,
  "version": "0.1.0",
  "type": "module",
  "description": "Wormhole - a retro-inspired Tron-style tube flyer",
  "scripts": {
    "dev": "vite",
    "build": "tsc --noEmit && vite build",
    "preview": "vite preview",
    "typecheck": "tsc --noEmit",
    "shoot": "node scripts/shoot.ts",
    "sim": "esbuild scripts/combat-sim.ts --bundle --platform=node --format=esm --outfile=node_modules/.cache/combat-sim.mjs && node node_modules/.cache/combat-sim.mjs",
    "sim:levels": "esbuild scripts/levels-sim.ts --bundle --platform=node --format=esm --outfile=node_modules/.cache/levels-sim.mjs && node node_modules/.cache/levels-sim.mjs"
  },
  "dependencies": {
    "three": "^0.184.0"
  },
  "devDependencies": {
    "@types/three": "^0.184.1",
    "esbuild": "^0.28.0",
    "playwright": "^1.60.0",
    "typescript": "^6.0.3",
    "vite": "^8.0.16"
  },
  "allowScripts": {
    "esbuild@0.28.1": true
  }
}
